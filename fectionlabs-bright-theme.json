    "tab.activeForeground": "#0F1D2E",
    "tab.inactiveForeground": "#3D556D",
    "sideBar.background": "#F0F6FC",
    "sideBar.foreground": "#0F1D2E",
    "sideBar.border": "#03497245",
    "sideBarTitle.foreground": "#034972",
    "activityBar.background": "#034972",
    "activityBar.foreground": "#FFFFFF",
    "activityBar.border": "#D4A853",
    "activityBarBadge.background": "#D4A853",
    "activityBarBadge.foreground": "#0F1D2E",
    "statusBar.background": "#023556",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.border": "#D4A853",
    "statusBarItem.prominentBackground": "#034972",
    "titleBar.activeBackground": "#034972",
    "titleBar.activeForeground": "#FFFFFF",
    "titleBar.inactiveBackground": "#EEF3F9",
    "titleBar.inactiveForeground": "#3D556D",
    "list.activeSelectionBackground": "#034972",
    "list.activeSelectionForeground": "#FFFFFF",
    "list.hoverBackground": "#E8F2FA",
    "list.inactiveSelectionBackground": "#03497220",
    "list.focusOutline": "#D4A853",
    "input.background": "#FFFFFF",
    "input.foreground": "#0F1D2E",
    "input.border": "#03497270",
    "button.background": "#023556",
    "button.foreground": "#FFFFFF",
    "dropdown.background": "#FFFFFF",
    "dropdown.foreground": "#0F1D2E",
    "dropdown.border": "#03497270",
    "panel.background": "#F8FBFF",
    "panel.border": "#03497245",
    "panelTitle.activeForeground": "#034972",
    "panelTitle.inactiveForeground": "#5C7086",
    "badge.background": "#034972",
    "badge.foreground": "#FFFFFF",
    "focusBorder": "#0D9488",
    "progressBar.background": "#D4A853",
    "sash.hoverBorder": "#0D9488",
    "scrollbarSlider.activeBackground": "#03497280",
    "editorWidget.background": "#FFFFFF",
    "editorWidget.foreground": "#0F1D2E",
    "editorWidget.border": "#D4A853",
    "peekView.border": "#D4A853",
    "terminal.background": "#F8FBFF",
    "terminal.foreground": "#0F1D2E",
    "terminal.ansiBlack": "#0F1D2E",
    "terminal.ansiRed": "#C42B1C",
    "terminal.ansiGreen": "#15703A",
    "terminal.ansiYellow": "#9A6700",
    "terminal.ansiBlue": "#034972",
    "terminal.ansiMagenta": "#7C3AED",
    "terminal.ansiCyan": "#0D6E6E",
    "terminal.ansiWhite": "#3D556D",
    "terminal.ansiBrightRed": "#E03E2D",
    "terminal.ansiBrightGreen": "#1B8A4A",
    "terminal.ansiBrightYellow": "#B8923A",
    "terminal.ansiBrightBlue": "#0568A6",
    "terminal.ansiBrightMagenta": "#9333EA",
    "terminal.ansiBrightCyan": "#0D9488",
    "terminal.ansiBrightWhite": "#0F1D2E",
    "notificationCenter.border": "#D4A853",
    "notificationsErrorIcon.foreground": "#C42B1C"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#5C7086", "fontStyle": "italic" } },
    { "scope": ["string", "punctuation.definition.string", "constant.other.symbol"], "settings": { "foreground": "#B42318" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#9A6700", "fontStyle": "bold" } },
    { "scope": ["keyword", "keyword.control", "keyword.operator.new"], "settings": { "foreground": "#023556", "fontStyle": "bold" } },
    { "scope": ["storage.type", "storage.modifier"], "settings": { "foreground": "#034972" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call"], "settings": { "foreground": "#C2410C", "fontStyle": "bold" } },
    { "scope": ["variable", "variable.other", "variable.parameter"], "settings": { "foreground": "#0F2744" } },
    { "scope": ["entity.name.type", "entity.other.inherited-class", "support.type", "support.class"], "settings": { "foreground": "#7C5C00" } },
    { "scope": ["entity.name.tag", "punctuation.definition.tag"], "settings": { "foreground": "#15703A", "fontStyle": "bold" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#0D6E6E" } },
    { "scope": ["entity.name.section", "markup.heading"], "settings": { "foreground": "#034972", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "foreground": "#0F1D2E", "fontStyle": "bold" } },
    { "scope": ["markup.italic", "markup.quote"], "settings": { "foreground": "#3D556D", "fontStyle": "italic" } },
    { "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#0568A6", "fontStyle": "underline" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#9333EA" } },
    { "scope": ["punctuation", "meta.brace"], "settings": { "foreground": "#3D556D" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#023556" } },
    { "scope": ["support.constant", "constant.other.color"], "settings": { "foreground": "#9A6700" } },
    { "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#C42B1C", "fontStyle": "underline" } },
    { "scope": "token.info-token", "settings": { "foreground": "#034972" } },
    { "scope": "token.warn-token", "settings": { "foreground": "#9A6700" } },
    { "scope": "token.error-token", "settings": { "foreground": "#C42B1C" } },
    { "scope": "token.debug-token", "settings": { "foreground": "#0D6E6E" } }
  ]
}
