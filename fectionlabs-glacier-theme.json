{
  "name": "FectionLabs Theme Glacier",
  "type": "light",
  "colors": {
    "editor.background": "#F0F9FF",
    "editor.foreground": "#0C2340",
    "editorCursor.foreground": "#0369A1",
    "editor.lineHighlightBackground": "#E0F2FE",
    "editor.selectionBackground": "#0369A140",
    "editor.wordHighlightBackground": "#BAE6FD",
    "editor.wordHighlightStrongBackground": "#0369A130",
    "editorBracketMatch.border": "#D4A853",
    "editorIndentGuide.background": "#A8D4F0",
    "editorIndentGuide.activeBackground": "#0369A1",
    "editorLineNumber.foreground": "#5A8BAD",
    "editorLineNumber.activeForeground": "#0369A1",
    "tab.activeBorderTop": "#D4A853",
    "tab.activeBorder": "#D4A853",
    "tab.activeForeground": "#0C2340",
    "tab.inactiveForeground": "#3D6080",
    "activityBar.background": "#0369A1",
    "activityBar.foreground": "#FFFFFF",
    "activityBar.border": "#D4A853",
    "statusBar.background": "#0C4A6E",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.border": "#D4A853",
    "sideBar.background": "#E8F6FC",
    "sideBar.foreground": "#0C2340",
    "titleBar.activeBackground": "#0369A1",
    "titleBar.activeForeground": "#FFFFFF",
    "focusBorder": "#0EA5E9",
    "progressBar.background": "#D4A853",
    "notificationCenter.border": "#D4A853"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#4A6B85", "fontStyle": "italic" } },
    { "scope": ["string", "punctuation.definition.string"], "settings": { "foreground": "#0E7490" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#9A6700", "fontStyle": "bold" } },
    { "scope": ["keyword", "keyword.control"], "settings": { "foreground": "#0369A1", "fontStyle": "bold" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#7C3AED", "fontStyle": "bold" } },
    { "scope": ["variable"], "settings": { "foreground": "#0C2340" } },
    { "scope": ["entity.name.type", "support.type"], "settings": { "foreground": "#034972" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#047857", "fontStyle": "bold" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#0D6E6E" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#0C4A6E", "fontStyle": "bold" } },
    { "scope": ["invalid"], "settings": { "foreground": "#DC2626", "fontStyle": "underline" } }
  ]
}
