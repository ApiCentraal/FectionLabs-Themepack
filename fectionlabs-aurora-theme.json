{
  "name": "FectionLabs Theme Aurora",
  "type": "dark",
  "colors": {
    "editor.background": "#0B1220",
    "editor.foreground": "#E2E8F4",
    "editorCursor.foreground": "#A78BFA",
    "editor.lineHighlightBackground": "#141E32",
    "editor.selectionBackground": "#5B4B8A66",
    "editor.selectionHighlightBackground": "#0D948844",
    "editor.wordHighlightBackground": "#1A2540",
    "editor.wordHighlightStrongBackground": "#7C3AED44",
    "editorBracketMatch.border": "#D4A853",
    "editorBracketMatch.background": "#0D948833",
    "editorIndentGuide.background": "#1A2540",
    "editorIndentGuide.activeBackground": "#A78BFA",
    "editorLineNumber.foreground": "#4A5A78",
    "editorLineNumber.activeForeground": "#C4B5FD",
    "editorGutter.background": "#0B1220",
    "editorGroup.border": "#0D948855",
    "editorGroupHeader.tabsBackground": "#080E18",
    "tab.activeBackground": "#0B1220",
    "tab.inactiveBackground": "#080E18",
    "tab.activeBorderTop": "#D4A853",
    "tab.activeBorder": "#D4A853",
    "tab.activeForeground": "#F5F3FF",
    "tab.inactiveForeground": "#8B9CB8",
    "activityBar.background": "#1E3A5F",
    "activityBar.foreground": "#E2E8F4",
    "activityBar.border": "#D4A853",
    "activityBarBadge.background": "#D4A853",
    "activityBarBadge.foreground": "#0B1220",
    "sideBar.background": "#0F1728",
    "sideBar.foreground": "#C7D2E8",
    "sideBar.border": "#0D948866",
    "sideBarTitle.foreground": "#A78BFA",
    "list.activeSelectionBackground": "#5B4B8A",
    "list.activeSelectionForeground": "#FFFFFF",
    "list.hoverBackground": "#141E32",
    "list.focusOutline": "#D4A853",
    "titleBar.activeBackground": "#1E3A5F",
    "titleBar.activeForeground": "#E2E8F4",
    "statusBar.background": "#162A45",
    "statusBar.foreground": "#E2E8F4",
    "statusBar.border": "#D4A853",
    "statusBarItem.prominentBackground": "#0D9488",
    "panel.background": "#0F1728",
    "panel.border": "#7C3AED44",
    "panelTitle.activeForeground": "#C4B5FD",
    "terminal.background": "#0B1220",
    "terminal.foreground": "#E2E8F4",
    "terminal.ansiGreen": "#5EEAD4",
    "terminal.ansiYellow": "#D4A853",
    "terminal.ansiBlue": "#8BB8E8",
    "terminal.ansiMagenta": "#C4B5FD",
    "terminal.ansiCyan": "#0D9488",
    "terminal.ansiRed": "#F0A0A8",
    "input.background": "#141E32",
    "input.border": "#7C3AED66",
    "button.background": "#1E3A5F",
    "button.foreground": "#FFFFFF",
    "badge.background": "#7C3AED",
    "badge.foreground": "#FFFFFF",
    "focusBorder": "#A78BFA",
    "progressBar.background": "#D4A853",
    "sash.hoverBorder": "#0D9488",
    "editorWidget.border": "#D4A853",
    "notificationCenter.border": "#D4A853"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#7A8BA8", "fontStyle": "italic" } },
    { "scope": ["string", "punctuation.definition.string"], "settings": { "foreground": "#99F6E4" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#D4A853" } },
    { "scope": ["keyword"], "settings": { "foreground": "#A78BFA", "fontStyle": "bold" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#5EEAD4" } },
    { "scope": ["variable"], "settings": { "foreground": "#E2E8F4" } },
    { "scope": ["storage.type", "storage.modifier"], "settings": { "foreground": "#0D9488" } },
    { "scope": ["entity.name.type", "entity.other.inherited-class"], "settings": { "foreground": "#D4A853" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#C4B5FD" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#8BB8E8" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#D4A853", "fontStyle": "bold" } }
  ]
}
